GMAIL_ADDRESS=Youremail_id
GMAIL_APP_PASSWORD=**** **** **** ****

# Comma/semicolon/newline separated list of sender emails to monitor
SOURCE_SENDER_EMAILS=abc@substack.com,xyz@gmail.com...............

# Where the combined daily digest should be sent
SUMMARY_TO_EMAIL=Youremail_id

# Service loop frequency (seconds)
POLL_SECONDS=60

# Run digest every N hours
DIGEST_INTERVAL_HOURS=4
TIMEZONE=Asia/Kolkata

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Local state persistence file
STATE_FILE=processed_state.json

# Optional: Vercel web portal integration
# PORTAL_API_URL=https://your-portal.vercel.app
# PORTAL_API_SECRET=your_shared_secret_here
